{
  "name": "jagantara",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clear-ports": "./scripts/clear-ports.sh",
    "dev": "bun run clear-ports && concurrently \"bun run dev:frontend\" \"bun run dev:backend\"",
    "build": "bun --cwd frontend run build && bun --cwd backend run build",
    "dev:backend": "bun run --hot ./backend/src/index.ts",
    "db:push": "drizzle-kit push",
    "dev:frontend": "vite",
    "build:frontend": "tsc -b && vite build",
    "lint:frontend": "eslint .",
    "preview:frontend": "vite preview"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.17.0",
    "@lucia-auth/adapter-sqlite": "^3.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.163.3",
    "@types/react-grid-layout": "1.3.5",
    "aedes": "^1.0.0",
    "clsx": "2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "12.34.5",
    "hono": "^4.0.0",
    "libsql": "^0.3.0",
    "lucia": "^3.0.0",
    "lucide-react": "^0.577.0",
    "net": "^1.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grid-layout": "1.4.4",
    "react-resizable": "^3.1.3",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "^4.2.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/router-plugin": "^1.164.0",
    "@tanstack/router-vite-plugin": "^1.164.0",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^8.0.0-beta.13"
  }
}